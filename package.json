{
  "name": "jtools-desktop",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "prepare:webview2loader": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare-webview2loader.ps1",
    "tauri": "tauri",
    "tauri:build:win": "bun run prepare:webview2loader && tauri build --config src-tauri/tauri.windows.conf.json --bundles nsis"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "element-plus": "^2.11.7",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
