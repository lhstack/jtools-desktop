{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jtools",
  "version": "0.0.3",
  "identifier": "com.jtools.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "jtools",
        "width": 1120,
        "height": 116,
        "minWidth": 1120,
        "minHeight": 116,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../plugins/builtin": "plugins/builtin",
      "resources/WebView2Loader.dll": "resources/WebView2Loader.dll"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
